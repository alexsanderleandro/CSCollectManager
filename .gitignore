# .gitignore geral para projetos Python

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
*.egg-info/
.installed.cfg
*.egg
pip-wheel-metadata/

# PyInstaller
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/

# Pytest
.pytest_cache/

# Django stuff:
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal

# Flask instance folder
instance/
.webassets-cache

# Scrapy
.scrapy

# Sphinx docs
docs/_build/

# PyBuilder
target/

# Jupyter
.ipynb_checkpoints

# IPython
profile_default/
ipython_config.py

# pyenv
.python-version

# pipenv
Pipfile.lock

# poetry
poetry.lock

# Environments
.env
.venv/
venv/
ENV/
env/
env.bak/
venv.bak/

# IDEs / Editors
.vscode/
.idea/
*.sublime-workspace
*.sublime-project

# Spyder
.spyderproject
.spyproject

# Rope
.ropeproject

# mkdocs
/site

# mypy
.mypy_cache/

# OS files
.DS_Store
Thumbs.db

# Logs and DBs
*.log
*.sqlite3
*.db

# Local config files (protegidos)
user_settings.json
nome_device.json

# Misc caches and temp
*.cache
*.tmp

.env